# 게임원(gameone.kr) 로그인 계정 — 데이터가 전부 로그인 벽 뒤에 있어 필요합니다.
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요:  cp .env.example .env
# .env 는 .gitignore 에 등록되어 커밋/공유되지 않습니다.
GAMEONE_USER_ID=
GAMEONE_PASSWD=

# 우리 리그 / 팀 식별자 (이미 파악됨 — 보통 수정 불필요)
LIG_IDX=85
CLUB_IDX=22098
OUR_GROUP_CODE=25

# Claude API (라인업/전략 AI). 콘솔에서 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=
