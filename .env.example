# 이 파일을 .env 로 복사한 뒤 본인 게임원 계정만 채우세요.
#   macOS/Linux:  cp .env.example .env
#   Windows:      copy .env.example .env
# .env 는 .gitignore 처리되어 커밋/공유되지 않습니다. (각자 본인 계정, 절대 공유 금지)
#
# 채울 값은 아래 둘뿐입니다. (LLM API 키 불필요 — 분석은 Claude가 직접 합니다.)
GAMEONE_USER_ID=
GAMEONE_PASSWD=

# (선택) 다른 팀/리그로 쓸 때만 주석 해제해서 덮어쓰기 — 우리 팀원은 건드리지 마세요.
# LIG_IDX=85
# CLUB_IDX=22098
# OUR_JO=B
# OUR_BUJO_IDX=45493
# CURRENT_SEASON=2026
